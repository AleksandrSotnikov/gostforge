# Пример конфигурации для docker-compose. Скопируйте в .env и
# заполните значения. Файл .env в репозиторий НЕ коммитится.

# Bind-адрес для проброса наружу (REST API).
# 127.0.0.1 — слушаем только loopback (для reverse-proxy).
# 0.0.0.0   — слушаем все интерфейсы (только если фронт у вас — TLS-прокси).
GOSTFORGE_BIND=127.0.0.1

# Bind-адрес для Streamlit UI (отдельный сервис в docker-compose).
GOSTFORGE_UI_BIND=127.0.0.1

# API-ключи (comma-separated). Минимум 8 символов на ключ.
# Если пусто — auth выключен (запросы анонимны).
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
GOSTFORGE_API_KEYS=

# CORS-origins (comma-separated). Пусто → CORS запрещён.
# Пример: https://lms.example.com,https://kafedra.example.ru
GOSTFORGE_CORS_ORIGINS=

# Лимит размера загружаемого файла в МБ.
GOSTFORGE_MAX_UPLOAD_MB=25

# Путь к локальной SQLite-БД (история проверок).
# В Docker используется volume gostforge-data, монтируемый в
# /var/lib/gostforge — переопределять не нужно.
# Для CLI/UI без Docker — оставьте пустым, БД будет в ~/.gostforge/.
# GOSTFORGE_DB_PATH=
